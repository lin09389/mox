# ===========================================
# Mox .gitignore
# ===========================================

# ---- Python bytecode ----
__pycache__/
*.py[cod]
*$py.class
*.so

# ---- Python packaging / build ----
build/
dist/
*.egg-info/
*.egg
develop-eggs/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
MANIFEST

# ---- Virtual environments ----
venv/
env/
.venv/
ENV/

# ---- Test & coverage ----
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
*.cover
*.pycover
.tox/
.nox/
.cache/

# ---- Type checkers / linters ----
.mypy_cache/
.ruff_cache/
.pyre/
.pytype/
.dmypy.json
dmypy.json

# ---- Runtime data: databases ----
data/
*.db
*.db-journal
*.db-wal
*.db-shm
*.sqlite
*.sqlite3
*.sqlite-journal

# ---- Logs & trace output ----
*.log
logs/
trace_*.log
trace.log
import_check*.py

# ---- Debug artifacts ----
debug_*
*.debug

# ---- Temporary & backup files ----
*.tmp
*.temp
*.bak
*.old
*.orig
*.rej
*.swp
*.swo
*~
*.pid

# ---- Profiler & benchmark output ----
*.prof
*.pstats
cProfile_*

# ---- Attack loop / test output ----
attack_loop_results/
test_output/

# ---- Environment & secrets ----
.env
.env.local
.env.*.local
.env.production
.env.staging
*.pem
*.key
*.crt
*.csr
secrets/
secrets.json

# ---- IDE / Editor ----
.idea/
.vscode/
*.code-workspace
.project
.pydevproject
.settings/
*.sublime-*
.fleet/

# ---- OS-specific ----
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ---- Windows reserved names (nul, con, prn, aux, com1-9, lpt1-9) ----
nul
con
prn
aux
com1
com2
com3
com4
com5
com6
com7
com8
com9
lpt1
lpt2
lpt3
lpt4
lpt5
lpt6
lpt7
lpt8
lpt9

# ---- Security scan reports ----
bandit-report.json
bandit-report.txt
safety-report.json
safety-report.txt
pip-audit-report.*

# ---- AI assistant / agent tooling (local only) ----
.claude/
.trae/
.qwen/
.aider*
.cursor/
.continue/
.codeium/

# ---- Documentation build ----
site/
_docs_build/

# ---- Frontend (Node/Vite/React) ----
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/build/
frontend/tsconfig.tsbuildinfo
frontend/.env.local
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
node_modules/

# ---- Jupyter ----
.ipynb_checkpoints/
*.ipynb_checkpoints

# ---- Local tooling / scratch ----
scratch/
local/
private/
agent-tools/
mcps/
terminals/
