# Mox - LLM Adversarial Attack & Defense Platform
# Copy this file to .env and fill in your configuration

# ===========================================
# API Keys (Required for LLM operations)
# ===========================================

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# MiniMax
MINIMAX_API_KEY=your-minimax-api-key
MINIMAX_GROUP_ID=your-minimax-group-id

# DeepSeek
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# Cohere
COHERE_API_KEY=your-cohere-api-key

# Groq
GROQ_API_KEY=your-groq-api-key

# Google Gemini
GOOGLE_API_KEY=your-google-api-key

# Azure OpenAI
AZURE_OPENAI_API_KEY=your-azure-api-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-02-01

# ===========================================
# Ollama (Local Models)
# ===========================================
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3

# ===========================================
# Model Settings
# ===========================================
MOX_DEFAULT_MODEL=gpt-4
MOX_DEFAULT_TEMPERATURE=0.7
MOX_MAX_TOKENS=2048

# ===========================================
# Local Model Configuration
# ===========================================
MOX_LOCAL_MODEL_PATH=
MOX_LORA_ADAPTER_PATH=
MOX_LOAD_IN_4BIT=false
MOX_LOAD_IN_8BIT=false
MOX_DEVICE_MAP=auto
MOX_TORCH_DTYPE=bfloat16

# ===========================================
# Attack Settings
# ===========================================
MOX_MAX_ITERATIONS=100
MOX_ATTACK_SUCCESS_THRESHOLD=0.8
MOX_ATTACK_TIMEOUT=300

# ===========================================
# Defense Settings
# ===========================================
MOX_DEFENSE_ENABLED=true
MOX_INPUT_FILTER_ENABLED=true
MOX_OUTPUT_FILTER_ENABLED=true
MOX_HARDENING_ENABLED=true

# ===========================================
# Server Settings
# ===========================================
MOX_HOST=0.0.0.0
MOX_PORT=8000
MOX_DEBUG=false
MOX_LOG_LEVEL=INFO
MOX_WORKERS=4

# ===========================================
# Security Settings (Critical for Production)
# ===========================================

# JWT Secret Key - CHANGE THIS IN PRODUCTION!
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
MOX_SECRET_KEY=change-this-to-a-random-secret-key-at-least-32-characters-long

# Authentication
MOX_REQUIRE_AUTH=true
MOX_JWT_EXPIRATION_MINUTES=30

# Rate Limiting
MOX_RATE_LIMIT_PER_MINUTE=60
MOX_RATE_LIMIT_BURST=10

# Login Security
MOX_MAX_LOGIN_ATTEMPTS=5
MOX_LOGIN_LOCKOUT_DURATION_MINUTES=15

# Allowed IPs (comma-separated, empty = allow all)
MOX_ALLOWED_IPS=

# Admin credentials (CHANGE IN PRODUCTION!)
MOX_ADMIN_USERNAME=admin
MOX_ADMIN_PASSWORD=admin

# ===========================================
# CORS Settings
# ===========================================
# Allowed origins (comma-separated)
MOX_CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000
MOX_CORS_ALLOW_CREDENTIALS=true
MOX_CORS_MAX_AGE=600

# ===========================================
# Database Settings
# ===========================================
# SQLite (default for development)
MOX_DATABASE_URL=sqlite+aiosqlite:///data/mox.db

# PostgreSQL (recommended for production)
# MOX_DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/mox

# Pool settings
MOX_DB_POOL_SIZE=10
MOX_DB_MAX_OVERFLOW=20
MOX_DB_POOL_TIMEOUT=30
MOX_DB_POOL_RECYCLE=3600

# ===========================================
# Redis Settings
# ===========================================
MOX_REDIS_URL=redis://localhost:6379
MOX_REDIS_ENABLED=true
MOX_REDIS_DB=0
MOX_CACHE_TTL=3600

# ===========================================
# Celery Task Queue
# ===========================================
MOX_CELERY_BROKER_URL=redis://localhost:6379/1
MOX_CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ===========================================
# Monitoring & Observability
# ===========================================
MOX_METRICS_ENABLED=true
MOX_METRICS_PORT=9090
MOX_TRACING_ENABLED=false
MOX_TRACING_ENDPOINT=http://localhost:4317

# Prometheus
PROMETHEUS_ENABLED=true

# ===========================================
# Docker/Production Settings
# ===========================================
# Data directory
MOX_DATA_DIR=/data

# Trusted proxies (comma-separated, empty = do not trust any proxy, "*" = trust all)
# WARNING: Using "*" is insecure - only use in trusted network environments
MOX_TRUSTED_PROXIES=

# Security headers
MOX_SECURITY_HEADERS_ENABLED=true
