# Mox - 大模型对抗攻防平台
# 复制此文件为 .env 并填入你的配置

# ===========================================
# API Keys
# ===========================================

# OpenAI
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key

# MiniMax
MINIMAX_API_KEY=your_minimax_api_key
MINIMAX_GROUP_ID=your_minimax_group_id

# DeepSeek
DEEPSEEK_API_KEY=your_deepseek_api_key

# Cohere
COHERE_API_KEY=your_cohere_api_key

# Groq
GROQ_API_KEY=your_groq_api_key

# Google
GOOGLE_API_KEY=your_google_api_key

# Azure OpenAI
AZURE_OPENAI_API_KEY=your_azure_api_key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-02-01

# ===========================================
# Model Settings
# ===========================================
MOX_DEFAULT_MODEL=abab2.5-chat
MOX_DEFAULT_TEMPERATURE=0.7
MOX_MAX_TOKENS=2048

# ===========================================
# Attack Settings
# ===========================================
MOX_MAX_ITERATIONS=100
MOX_ATTACK_SUCCESS_THRESHOLD=0.8

# ===========================================
# Defense Settings
# ===========================================
MOX_DEFENSE_ENABLED=true
MOX_INPUT_FILTER_ENABLED=true
MOX_OUTPUT_FILTER_ENABLED=true

# ===========================================
# Server Settings
# ===========================================
MOX_HOST=0.0.0.0
MOX_PORT=8000
MOX_DEBUG=false
MOX_LOG_LEVEL=INFO

# ===========================================
# Security Settings
# ===========================================
MOX_SECRET_KEY=change-this-to-a-random-secret-key-at-least-32-chars
MOX_REQUIRE_AUTH=false
MOX_RATE_LIMIT_PER_MINUTE=60
MOX_RATE_LIMIT_BURST=10
MOX_MAX_LOGIN_ATTEMPTS=5
MOX_LOGIN_LOCKOUT_DURATION_MINUTES=15

# IP 白名单 (逗号分隔)
MOX_ALLOWED_IPS=

# ===========================================
# CORS Settings
# ===========================================
# 允许的来源 (逗号分隔)
MOX_CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000
MOX_CORS_ALLOW_CREDENTIALS=true
MOX_CORS_MAX_AGE=600

# ===========================================
# Database Settings
# ===========================================
MOX_DATABASE_URL=sqlite+aiosqlite:///data/mox.db
MOX_DB_POOL_SIZE=10
MOX_DB_MAX_OVERFLOW=20
MOX_DB_POOL_TIMEOUT=30
MOX_DB_POOL_RECYCLE=3600

# ===========================================
# Redis Settings
# ===========================================
MOX_REDIS_URL=redis://localhost:6379
MOX_REDIS_ENABLED=false
MOX_CACHE_TTL=3600

# ===========================================
# Monitoring Settings
# ===========================================
MOX_METRICS_ENABLED=true
MOX_TRACING_ENABLED=false
MOX_METRICS_PORT=9090