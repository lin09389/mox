# Mox - LLM Adversarial Attack & Defense Platform
# Copy this file to `.env` and fill in your configuration.
#
# NOTE: All Mox settings use the `MOX_` prefix. Variables written without the
# prefix (e.g. `OPENAI_API_KEY`) are still accepted for backward compatibility
# but will emit a DeprecationWarning on startup. Please migrate to `MOX_`.

# ===========================================
# API Keys (Required for LLM operations)
# ===========================================

# OpenAI
MOX_OPENAI_API_KEY=sk-your-openai-api-key
MOX_OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic
MOX_ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# MiniMax
MOX_MINIMAX_API_KEY=your-minimax-api-key
MOX_MINIMAX_GROUP_ID=your-minimax-group-id

# DeepSeek
MOX_DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# Cohere
MOX_COHERE_API_KEY=your-cohere-api-key

# Groq
MOX_GROQ_API_KEY=your-groq-api-key

# Google Gemini
MOX_GOOGLE_API_KEY=your-google-api-key

# Azure OpenAI
AZURE_OPENAI_API_KEY=your-azure-api-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-02-01

# ===========================================
# Ollama (Local Models)
# ===========================================
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3

# ===========================================
# Model Settings
# ===========================================
MOX_DEFAULT_MODEL=gpt-4
MOX_DEFAULT_TEMPERATURE=0.7
MOX_MAX_TOKENS=2048

# ===========================================
# Attack Settings
# ===========================================
MOX_MAX_ITERATIONS=100
MOX_ATTACK_SUCCESS_THRESHOLD=0.8
MOX_ATTACK_TIMEOUT=300

# ===========================================
# Defense Settings
# ===========================================
MOX_DEFENSE_ENABLED=true
MOX_INPUT_FILTER_ENABLED=true
MOX_OUTPUT_FILTER_ENABLED=true
MOX_HARDENING_ENABLED=true

# ===========================================
# Server Settings
# ===========================================
MOX_HOST=0.0.0.0
MOX_PORT=8000
MOX_DEBUG=false
MOX_LOG_LEVEL=INFO
MOX_WORKERS=4

# ===========================================
# Security Settings (Critical for Production)
# ===========================================

# JWT Secret Key - CHANGE THIS IN PRODUCTION!
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
MOX_SECRET_KEY=change-this-to-a-random-secret-key-at-least-32-characters-long

# Authentication
MOX_REQUIRE_AUTH=true
MOX_JWT_EXPIRATION_MINUTES=30

# Rate Limiting
MOX_RATE_LIMIT_PER_MINUTE=60
MOX_RATE_LIMIT_BURST=10

# Login Security
MOX_MAX_LOGIN_ATTEMPTS=5
MOX_LOGIN_LOCKOUT_DURATION_MINUTES=15

# Allowed IPs (comma-separated, empty = allow all)
MOX_ALLOWED_IPS=

# Default users (format: username:password:email:scopes, multiple users separated by |).
# Example: MOX_DEFAULT_USERS=admin:CHANGE_ME_STRONG_PASSWORD:admin@mox.ai:admin,attack,defense,eval
# SECURITY: Leave empty in production and provision users via your database,
#           or set a strong unique password. Never use the literal placeholder below.
MOX_DEFAULT_USERS=

# ===========================================
# CORS Settings
# ===========================================
# Allowed origins (comma-separated)
MOX_CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000
MOX_CORS_ALLOW_CREDENTIALS=true
MOX_CORS_MAX_AGE=600

# ===========================================
# Database Settings
# ===========================================
# SQLite (default for development)
MOX_DATABASE_URL=sqlite+aiosqlite:///data/mox.db

# PostgreSQL (recommended for production)
# MOX_DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/mox

# Pool settings
MOX_DB_POOL_SIZE=10
MOX_DB_MAX_OVERFLOW=20
MOX_DB_POOL_TIMEOUT=30
MOX_DB_POOL_RECYCLE=3600

# ===========================================
# Redis Settings
# ===========================================
MOX_REDIS_URL=redis://localhost:6379
MOX_REDIS_ENABLED=true
MOX_REDIS_DB=0
MOX_CACHE_TTL=3600

# ===========================================
# Celery Task Queue
# ===========================================
MOX_CELERY_BROKER_URL=redis://localhost:6379/1
MOX_CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ===========================================
# Monitoring & Observability
# ===========================================
MOX_METRICS_ENABLED=true
MOX_METRICS_PORT=9090
MOX_TRACING_ENABLED=false
MOX_TRACING_ENDPOINT=http://localhost:4317

# Prometheus
PROMETHEUS_ENABLED=true

# ===========================================
# Docker/Production Settings
# ===========================================
# Data directory
MOX_DATA_DIR=/data

# Trusted proxies
MOX_TRUSTED_PROXIES=*

# Security headers
MOX_SECURITY_HEADERS_ENABLED=true
